# ==============================================================================
# Home Inventory System - Environment Configuration Template
# ==============================================================================
# 說明：
# 1. 複製此檔案並更名為 .env
# 2. 根據你的開發環境調整以下變數
# 3. .env 已被加入 .gitignore，請勿提交實際的私人 IP 到 Git
# ==============================================================================

# --- Database (PostgreSQL) ---
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=inventory_db
POSTGRES_DB_ACCOUNTING=agent_accounting_db
POSTGRES_PORT=5432
DB_HOST=localhost

# --- Backend (Spring Boot) ---
BACKEND_PORT=8080
BACKEND_HOST=localhost

# --- Observability (LGTM Stack) ---
GRAFANA_ADMIN_PASSWORD=admin

# --- Infrastructure (MinIO) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# --- Message Queue (RabbitMQ) ---
RABBITMQ_PORT=5672
RABBITMQ_UI_PORT=15672

# --- Frontend & CORS ---
FRONTEND_PORT=4200
FRONTEND_API_URL=/api
# 多個來源請用逗號隔開 (例如: http://localhost:4200,http://192.168.0.100:4200)
ALLOWED_ORIGINS=http://localhost:4200

# --- OpenTelemetry (Tracing) ---
# OTel Collector 的 HTTP 接收位址 (通常為 4318 埠)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# --- Remote Development / Proxy Settings ---
# 允許連接到前端開發伺服器的 Host (解決遠端開發時的 Host Check 報錯)
# 範例: localhost,mac-mini.local,192.168.0.100
ALLOWED_HOSTS=localhost
