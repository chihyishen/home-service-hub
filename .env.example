# ==============================================================================
# Home Inventory System - Environment Configuration Template
# ==============================================================================

# --- 1. 資料庫 (PostgreSQL) ---
POSTGRES_USER=user
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_PORT=5432
DB_HOST=localhost
INVENTORY_DB=inventory_db
ACCOUNTING_DB=accounting_db
STOCK_DB=stock_portfolio_db

# --- 2. 基礎設施 (Infrastructure) ---
# Host-side published ports default to loopback. Do not use 0.0.0.0 unless the
# services are protected by an explicit firewall or gateway policy.
INFRA_BIND_HOST=127.0.0.1
APP_BIND_HOST=127.0.0.1
GRAFANA_ADMIN_PASSWORD=change-me-grafana-admin-password
MINIO_ROOT_USER=change-me-minio-root-user
MINIO_ROOT_PASSWORD=change-me-minio-root-password
# Backend SDK connection; MinIO remains host-loopback only.
MINIO_ENDPOINT=http://127.0.0.1:9000
# Browser-facing same-origin route served through the frontend proxy.
MINIO_PUBLIC_ENDPOINT=/minio
RABBITMQ_PORT=5672
RABBITMQ_UI_PORT=15672
INFRA_HOST=localhost

# --- 3. 庫存管理服務 (Java: inventory-item-service) ---
INVENTORY_ITEM_SERVICE_HOST=localhost
INVENTORY_ITEM_SERVICE_PORT=8080
INVENTORY_SERVER_ADDRESS=127.0.0.1
SPRING_APPLICATION_NAME=inventory-item-service

# Inventory diagnostics are opt-in because API schemas and SQL details may
# expose internal structure or user data.
INVENTORY_API_DOCS_ENABLED=false
INVENTORY_SQL_QUERY_TEXT_ENABLED=false
INVENTORY_SQL_PARAMETER_VALUES_ENABLED=false
INVENTORY_SQL_QUERY_ARGUMENTS_ENABLED=false
INVENTORY_HIBERNATE_SQL_LOG_LEVEL=OFF
INVENTORY_HTTP_QUERY_LOGGING_ENABLED=false
INVENTORY_HTTP_PAYLOAD_LOGGING_ENABLED=false
INVENTORY_LOGBOOK_LOG_LEVEL=OFF

# --- 4. 會計管理服務 (Python: accounting-service) ---
ACCOUNTING_SERVICE_HOST=localhost
ACCOUNTING_SERVICE_PORT=8000
OTEL_SERVICE_NAME_ACCOUNTING=accounting-service

# --- 4.5 投資組合服務 (Python: stock-portfolio-service) ---
STOCK_SERVICE_HOST=localhost
STOCK_SERVICE_PORT=8001
OTEL_SERVICE_NAME_STOCK=stock-portfolio-service

# --- 5. 前端與連線設定 (Frontend & CORS) ---
FRONTEND_PORT=4200
FRONTEND_API_URL=/api
ALLOWED_HOSTS=localhost,mac-mini.local
ALLOWED_ORIGINS=http://localhost:4200

# --- 6. 可觀測性 (OpenTelemetry) ---
# Java 使用 HTTP (4318), Python 使用 gRPC (4317)
OTEL_COLLECTOR_ENDPOINT_HTTP=http://localhost:4318
OTEL_COLLECTOR_ENDPOINT_GRPC=http://localhost:4317

# --- 7. 投資組合排程與重算開關 (Stock-portfolio service toggles) ---
# Set to "false" to disable the FastAPI background recalc chain after CSV import.
# The chain refreshes symbol_map, dividends, and networth snapshots; the
# manual POST /api/portfolio/imports/recalc endpoint still works regardless.
POST_IMPORT_RECALC_ENABLED=true

# Set to "false" to skip the in-process APScheduler boot (tw_daily_prices /
# quote_refresh / portfolio_snapshot). Tests and CI must set this to "false".
SCHEDULER_ENABLED=true
